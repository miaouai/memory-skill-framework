{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/miaouai/memory-skill-framework/main/schemas/memory-module.schema.json",
  "title": "Memory Module Base Schema",
  "description": "Core schema for all memory/data/*.json modules with versioning and metadata fields",
  
  "type": "object",
  "required": ["version", "last_updated"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.?\\d*$",
      "description": "Semantic version (e.g., 1.0, 2.3.1)",
      "examples": ["1.0", "2.0.1", "3.0"]
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of last modification"
    },
    "created_by": {
      "type": "string",
      "description": "Agent or user who created this module",
      "default": "system"
    },
    "search_tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Keywords for full-text search indexing"
    }
  },
  
  "additionalProperties": true
}
